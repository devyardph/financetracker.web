@inject IJSRuntime JSRuntime
@using System.Linq.Expressions
@using System.Globalization

@{
    var error = Errors?.GetError(FieldName);
    var disabledStyle = Disabled ? "bg-lighter" : string.Empty;
    var displayStyle = Display ? "" : "d-none";
}

<div class="@displayStyle">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label for="@Id-@Index" class="form-label">@Label</label>
    }
    <input type="text" class="form-control flatpickr-date @disabledStyle @Style"
           placeholder="@Placeholder"
           id="@Id-@Index"
           disabled="@Disabled"
           autocomplete="off"
           value="@Value"
           @onchange="OnTextInput" />

    @if (!string.IsNullOrEmpty(Note) && string.IsNullOrEmpty(error?.ErrorMessage))
    {
        <div id="note" class="form-text">
            @((MarkupString)Note)
        </div>
    }
</div>


@if (!string.IsNullOrEmpty(error?.ErrorMessage) && Display)
{
    <div id="error-message" class="form-text text-danger">
        @((MarkupString)(error?.ErrorMessage ?? string.Empty))
    </div>
}

@code {

    private bool _showValidation;
    [Parameter] public string Id { get; set; }
    [Parameter] public string Label { get; set; }
    [Parameter] public string Note { get; set; }
    [Parameter] public int Index { get; set; } = 0;
    [Parameter] public string Style { get; set; }
    [Parameter] public EventCallback<double?> ValueChanged { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> OnChanged { get; set; }

    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public bool IsReadOnly { get; set; } = false;
    [Parameter] public bool Required { get; set; } = false;
    [Parameter] public bool Display { get; set; } = true;

    [Parameter]
    public DateTime? ChosenDate { get; set; }
    public DateTime? TChosenDate { get; set; }

    [Parameter]
    public System.Globalization.CultureInfo Culture { get; set; }

    [Parameter]
    public EventCallback<DateTime?> ChosenDateChanged { set; get; }
    [Parameter]
    public EventCallback<DateTime?> PassChanged { set; get; }
    [Parameter]
    public string DateFormat { get; set; } = "dd MMM yyyy";
    [Parameter] public EventCallback<DateTime?> TriggerEvent { set; get; }
    [Parameter] public string Placeholder { set; get; } = "";
    [Parameter]
    public string FlatPickerFormat { get; set; } = "d M Y";
    [Parameter]
    public bool FlatPickerTimeEnabled { get; set; } = false;

    //FORM VALIDATION
    [Parameter] public List<ErrorDto>? Errors { get; set; } = new List<ErrorDto>();
    [Parameter] public string FieldName { get; set; }

    public string Value
    {
        get
        {
            if (TChosenDate != null)
            {

                return $"{TChosenDate.Value.ToString(DateFormat)}";
            }
            return string.Empty;
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            TChosenDate = ChosenDate ?? DateTime.Now;
            var defaulDateAndTime = ChosenDate.FormatDate("dd MMM yyyy hh:mmtt");
            JSRuntime.InvokeVoidAsync("setDateById", $"{@Id}-{@Index}", @FlatPickerFormat, ChosenDate.FormatDate("dd MMM yyyy hh:mmtt") , @FlatPickerTimeEnabled);
        }
        base.OnAfterRender(firstRender);
    }

    protected override Task OnParametersSetAsync()
    {
        TChosenDate = ChosenDate;
        return base.OnParametersSetAsync();
    }

    protected override void OnInitialized()
    {
        TChosenDate = ChosenDate?.Date;
        base.OnInitialized();
    }

    public async Task OnTextInput(ChangeEventArgs e)
    {

        var value = e.Value != null ? e.Value.ToString() : string.Empty;
        if (!string.IsNullOrEmpty(value))
        {
            var selectedDate = Convert.ToDateTime(value);
            TChosenDate = selectedDate;
        }
        else
        {
            TChosenDate = null;
            ChosenDate = null;
        }

        //RESET CURRENT FIELD ERROR
        foreach (var error in Errors!)
        {
            if (error.Field == FieldName)
            {
                error.ErrorMessage = string.Empty;
                error.Style = string.Empty;
            }
        }

        await ClickApply();
        await Task.Delay(1);
    }


    public async Task ClickApply()
    {
        if (TChosenDate.HasValue)
        {
            ChosenDate = TChosenDate;
            await ChosenDateChanged.InvokeAsync(TChosenDate.Value);
            await PassChanged.InvokeAsync(ChosenDate);
            await TriggerEvent.InvokeAsync(ChosenDate);
        }
        else
        {
            TChosenDate = null;
            ChosenDate = null;
            await ChosenDateChanged.InvokeAsync(null);
            await PassChanged.InvokeAsync(null);
            await TriggerEvent.InvokeAsync(null);
        }
    }

}