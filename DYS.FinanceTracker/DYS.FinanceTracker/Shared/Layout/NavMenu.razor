@using DYS.FinanceTracker.Shared.ViewModels
@inherits MvvmComponentBase<MenuViewModel>

 
<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
    <div class="app-brand demo">
        <a class="app-brand-link">
            <span class="app-brand-logo demo">
                <span class="text-primary">
                </span>
            </span>
            <span class="app-brand-text demo menu-text fw-bold ms-2">Appzy <sup>™</sup></span>
        </a>

          <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
                        <i class="bx bx-chevron-left d-block d-xl-none align-middle"></i>
                    </a>
    </div>

    <div class="menu-divider mt-0"></div>

    <div class="menu-inner-shadow"></div>

    <ul class="menu-inner py-1">
        @foreach (var menu in BindingContext.Menu)
        {
            <li class="menu-item @BooleanExtensions.GetConditionalString(menu.Id == BindingContext.ActiveMenu, "active","")">
                <a href="javascript:void(0)" class="menu-link menu-toggle" @onclick="@(() => BindingContext.NavigationToPath(menu.Id, menu.Path))">
                    <i class="menu-icon icon-base bx @menu.Icon"></i>
                    <div data-i18n="@menu.Title">@menu.Title</div>
                </a>
            </li>
        }
        <li class="menu-item">
            <a href="javascript:void(0)"  class="menu-link" @onclick="BindingContext.Signout">
                <i class="menu-icon icon-base bx bx-log-out"></i>
                <div data-i18n="Logout">Logout</div>
            </a>
        </li>
    </ul>
</aside>
@* <SessionStorageComponent @ref="BindingContext.SessionStorageComponent" /> *@

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender) StateHasChanged();
    }

}
